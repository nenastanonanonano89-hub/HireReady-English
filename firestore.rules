rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: feedback
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The ID of the user who provided the feedback.
    //   - aiResponse: string (required) - The AI's response text that is being rated.
    //   - rating: string (required) - 'up' or 'down'.
    //   - jobTitle: string (optional)
    //   - interviewType: string (optional)
    //   - englishLevel: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidFeedback() {
      let data = request.resource.data;
      return hasRequiredFields(['userId', 'aiResponse', 'rating', 'createdAt']) &&
             data.userId is string &&
             data.aiResponse is string && data.aiResponse.size() > 0 && data.aiResponse.size() < 10000 &&
             data.rating in ['up', 'down'] &&
             data.createdAt is timestamp &&
             (!('jobTitle' in data) || (data.jobTitle is string && data.jobTitle.size() < 200)) &&
             (!('interviewType' in data) || (data.interviewType is string && data.interviewType.size() < 100)) &&
             (!('englishLevel' in data) || (data.englishLevel is string && data.englishLevel.size() < 100));
    }

    match /feedback/{feedbackId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && 
                    isOwner(request.resource.data.userId) && 
                    isValidFeedback();
      allow update: if isAuthenticated() && 
                    isOwner(resource.data.userId) && 
                    isOwner(request.resource.data.userId) && 
                    isValidFeedback() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
